{
  "name": "blackroad-os",
  "displayName": "BlackRoad OS",
  "description": "AI-powered development tools for BlackRoad infrastructure",
  "version": "0.1.0",
  "publisher": "blackroad-os",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Snippets", "Programming Languages"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "blackroad.status", "title": "BlackRoad: Show Status" },
      { "command": "blackroad.deploy", "title": "BlackRoad: Deploy" },
      { "command": "blackroad.agents", "title": "BlackRoad: List Agents" }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
